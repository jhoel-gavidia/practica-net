@model Practica1.Models.Entidad.Colaborador

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Colaborador</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken();
            <input type="hidden" asp-for="IdColaborador" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>


            <div class="form-group">
            <label>Empresa</label>
            <select asp-for="IdEmpresa" class="form-control"
            asp-items="@(new SelectList(ViewBag.Empresas, "IdEmpresa", "RazonSocial"))">
            <option value="">-- Seleccione --</option>
        </select>
        <span asp-validation-for="IdEmpresa" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="NombColaborador" class="control-label"></label>
                <input asp-for="NombColaborador" class="form-control" />
                <span asp-validation-for="NombColaborador" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ApeColaborador" class="control-label"></label>
                <input asp-for="ApeColaborador" class="form-control" />
                <span asp-validation-for="ApeColaborador" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="DNI" class="control-label"></label>
                <input asp-for="DNI" class="form-control" />
                <span asp-validation-for="DNI" class="text-danger"></span>
            </div>

            <div class="form-group">
               <label>Sexo</label>
                <select asp-for="Sexo" class="form-control">
                    <option value="">-- Selecciona Sexo --</option>
                    <option value="M">Masculino</option>
                    <option value="F">Femenino</option>
                </select>
                <span asp-validation-for="Sexo" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Direccion" class="control-label"></label>
                <input asp-for="Direccion" class="form-control" />
                <span asp-validation-for="Direccion" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <input type="submit" value="Actualizar" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="ListadoColaborador">Atras</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
